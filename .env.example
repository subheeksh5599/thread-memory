# Supermemory cloud API (free tier)
SUPERMEMORY_API_KEY=sm_your_key_here

# Optional: Groq fallback for when Supermemory returns low-confidence results
GROQ_API_KEY=

# Container tag for your personal memory namespace
THREAD_CONTAINER_TAG=thread_user

# Sources to watch (comma-separated: browser,terminal,files)
THREAD_SOURCES=browser,terminal,files

# Watch paths
THREAD_WATCH_DIRS=~/projects,~/Documents
THREAD_BROWSER_DB=~/.mozilla/firefox
THREAD_SHELL_HISTORY=~/.bash_history,~/.zsh_history
